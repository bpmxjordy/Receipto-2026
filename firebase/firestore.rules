rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ── User profiles ──
    // Only the owner can read/write their own profile
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Receipts subcollection
      match /receipts/{receiptId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;

        // Receipt items subcollection
        match /items/{itemId} {
          allow read, write: if request.auth != null && request.auth.uid == uid;
        }
      }

      // Monthly aggregates (read-only for the user; written by cloud functions)
      match /monthly/{monthId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false; // Only cloud functions (admin SDK) write these
      }
    }

    // ── Categories ──
    // Any authenticated user can read; no client writes
    match /categories/{categoryId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Canonical items ──
    // Any authenticated user can read; only cloud functions write
    match /canonicalItems/{itemId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── Canonical item aliases ──
    match /canonicalItemAliases/{aliasId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
