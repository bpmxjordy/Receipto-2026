rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Users can only read/write within their own prefix
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == uid;

      // Write: only the owner, max 10 MB per file, images only
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Gemma model files — any authenticated user can read (downloaded on first launch)
    match /models/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false; // Only admin uploads
    }
  }
}
