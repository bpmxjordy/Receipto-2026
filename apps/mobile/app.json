{
  "expo": {
    "name": "Receipto",
    "slug": "receipto",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "receipto",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jordancartwright.receipto"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EAF5EC",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.jordancartwright.receipto"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#EAF5EC"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Receipto needs camera access to photograph receipts."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Receipto needs photo library access to import receipt photos."
        }
      ],
      "./modules/ocr/app.plugin.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
